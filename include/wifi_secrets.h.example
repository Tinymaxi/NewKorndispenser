#ifndef _WIFI_SECRETS_H
#define _WIFI_SECRETS_H

// Template for network credentials.
// Copy this file to wifi_secrets.h (same directory) and fill in your values.
// wifi_secrets.h is gitignored so real credentials never reach the repo.

#define WIFI_SSID        "your-network-name"
#define WIFI_PASSWORD    "your-network-password"

// Password for the Pico's own fallback access point (WPA2, >= 8 chars)
#define WIFI_AP_PASSWORD "choose-a-password"

#endif // _WIFI_SECRETS_H
